# ============================================================
# Email Phishing Agent — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# cp .env.example .env
# ============================================================

# --- IMAP (lectura de correos entrantes) ---
IMAP_HOST=imap.tuproveedor.com
IMAP_PORT=993
IMAP_USER=tubuzon@tudominio.com
IMAP_PASSWORD=tu_contraseña_imap

# --- SMTP (envío de respuestas) ---
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=465
SMTP_USER=tubuzon@tudominio.com
SMTP_PASSWORD=tu_contraseña_smtp
SMTP_FROM_ADDRESS=tubuzon@tudominio.com

# --- Base de datos MariaDB ---
DB_HOST=mariadb
DB_PORT=3306
DB_USER=email_agent
DB_PASSWORD=cambiar_esto
DB_NAME=email_phishing_agent

# --- Proveedores de IA ---
# Obtén tu clave en https://console.groq.com
GROQ_API_KEY=
# Obtén tu clave en https://openrouter.ai
OPENROUTER_API_KEY=

# --- Configuración del agente ---
CHECK_INTERVAL_MINUTES=5
AI_MODEL_GROQ=llama-3.3-70b-versatile
AI_MODEL_OPENROUTER=meta-llama/llama-3.3-70b-instruct

# --- Keycloak (autenticación) ---
KEYCLOAK_SERVER_URL=https://tu-keycloak.dominio.com/
KEYCLOAK_REALM=TuRealm
KEYCLOAK_CLIENT_ID=email-agent-ui
